"""Shared fixtures for all tests.

These fixtures are black-box friendly: `mock_settings` introspects the real
`app.config.Settings` at runtime (dataclass / pydantic / signature) and supplies
deterministic test values for all fields it can detect.
"""

from __future__ import annotations

import dataclasses
import inspect
from datetime import datetime, timezone
from enum import Enum
from pathlib import Path
from typing import Any, get_args, get_origin

import pytest


def _is_optional(annotation: Any) -> bool:
	origin = get_origin(annotation)
	if origin is None:
		return False
	args = get_args(annotation)
	return origin is type(None) or (origin is getattr(__import__("typing"), "Union") and type(None) in args)  # type: ignore[attr-defined]


def _strip_optional(annotation: Any) -> Any:
	origin = get_origin(annotation)
	args = get_args(annotation)
	if origin is getattr(__import__("typing"), "Union") and type(None) in args:  # type: ignore[attr-defined]
		non_none = [a for a in args if a is not type(None)]
		return non_none[0] if non_none else str
	return annotation


def _value_for_type(name: str, annotation: Any, tmp_path: Path) -> Any:
	"""Best-effort deterministic values for common types."""
	if annotation is None or annotation is inspect._empty:
		# Fallback by name heuristics
		lname = name.lower()
		if "url" in lname:
			return "https://example.test"
		if "path" in lname or "dir" in lname:
			return str(tmp_path)
		if "key" in lname or "token" in lname or "secret" in lname:
			return "test-secret"
		if lname.startswith("is_") or lname.endswith("_enabled"):
			return True
		return f"test_{name}"

	# Optional[T] -> value for T
	if _is_optional(annotation):
		annotation = _strip_optional(annotation)

	origin = get_origin(annotation)
	args = get_args(annotation)

	# Containers
	if origin in (list, tuple, set, dict):
		if origin is list:
			return []
		if origin is tuple:
			return ()
		if origin is set:
			return set()
		if origin is dict:
			return {}

	# Common scalars
	if annotation is str:
		lname = name.lower()
		if "url" in lname:
			return "https://example.test"
		if "env" in lname and "var" in lname:
			return "TEST_ENV_VAR"
		if "provider" in lname:
			return "test-provider"
		return f"test_{name}"
	if annotation is int:
		return 1
	if annotation is float:
		return 1.0
	if annotation is bool:
		return True
	if annotation is datetime:
		return datetime(2020, 1, 1, tzinfo=timezone.utc)
	if annotation is Path:
		return tmp_path / f"{name}.txt"

	# Enums
	try:
		if isinstance(annotation, type) and issubclass(annotation, Enum):
			return list(annotation)[0]
	except Exception:
		pass

	# Fallback for unknown annotations
	return f"test_{name}"


def _build_kwargs_for_settings(Settings: type, tmp_path: Path) -> dict[str, Any]:
	"""Extract fields from dataclass / pydantic / __init__ signature and fill values."""
	kwargs: dict[str, Any] = {}

	# dataclass
	try:
		if dataclasses.is_dataclass(Settings):
			for f in dataclasses.fields(Settings):
				ann = f.type
				if f.default is not dataclasses.MISSING:
					# Prefer explicit non-None defaults only when meaningful; otherwise fill deterministic.
					if f.default is not None:
						continue
				if f.default_factory is not dataclasses.MISSING:  # type: ignore[comparison-overlap]
					continue
				kwargs[f.name] = _value_for_type(f.name, ann, tmp_path)
			return kwargs
	except Exception:
		pass

	# pydantic v2: model_fields
	if hasattr(Settings, "model_fields"):
		model_fields = getattr(Settings, "model_fields")
		try:
			for name, field in model_fields.items():
				ann = getattr(field, "annotation", inspect._empty)
				kwargs[name] = _value_for_type(name, ann, tmp_path)
			return kwargs
		except Exception:
			pass

	# pydantic v1: __fields__
	if hasattr(Settings, "__fields__"):
		fields = getattr(Settings, "__fields__")
		try:
			for name, field in fields.items():
				ann = getattr(field, "outer_type_", inspect._empty)
				kwargs[name] = _value_for_type(name, ann, tmp_path)
			return kwargs
		except Exception:
			pass

	# Plain class: __init__ signature
	try:
		sig = inspect.signature(Settings)
		for pname, param in sig.parameters.items():
			if pname == "self":
				continue
			if param.default is not inspect._empty:
				# Use caller-supplied values only for required/empty defaults.
				continue
			kwargs[pname] = _value_for_type(pname, param.annotation, tmp_path)
	except Exception:
		# No usable signature
		return {}

	return kwargs


@pytest.fixture
def mock_settings(tmp_path: Path, monkeypatch: pytest.MonkeyPatch):
	"""A Settings instance populated with deterministic values.

	This is intentionally robust to differing Settings implementations.
	"""
	from app.config import Settings

	kwargs = _build_kwargs_for_settings(Settings, tmp_path)

	# Provide commonly-used env vars if Settings reads them implicitly.
	monkeypatch.setenv("TEST_ENV_VAR", "1")
	monkeypatch.setenv("OPENAI_API_KEY", "test-openai-key")
	monkeypatch.setenv("ANTHROPIC_API_KEY", "test-anthropic-key")

	try:
		if kwargs:
			return Settings(**kwargs)
		return Settings()
	except TypeError as e:
		raise AssertionError(
			f"Failed to construct Settings. Discovered kwargs={sorted(kwargs.keys())}. "
			f"Error: {e}"
		) from e
	except Exception as e:
		raise AssertionError(f"Failed to construct Settings with kwargs={kwargs!r}. Error: {e}") from e


@pytest.fixture
def sample_project() -> dict[str, Any]:
	return {
		"id": "proj_123",
		"name": "Test Project",
		"repo_url": "https://example.test/repo.git",
		"default_branch": "main",
		"created_at": "2020-01-01T00:00:00Z",
	}


@pytest.fixture
def sample_run() -> dict[str, Any]:
	return {
		"id": "run_123",
		"project_id": "proj_123",
		"status": "running",
		"phase": 1,
		"iteration": 0,
		"created_at": "2020-01-01T00:00:00Z",
	}


@pytest.fixture
def sample_user() -> dict[str, Any]:
	return {
		"id": "user_123",
		"email": "tester@example.test",
		"role": "tester",
		"created_at": "2020-01-01T00:00:00Z",
	}
