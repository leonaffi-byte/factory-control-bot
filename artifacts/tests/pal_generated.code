"""Unit tests for provider base DTOs (black-box, per interfaces-v2.md)."""

from __future__ import annotations

import dataclasses
from datetime import datetime, timezone
from typing import Any

import pytest

from app.providers.base import (
	CompletionResponse,
	HealthStatus,
	ModelInfo,
	ModelRecommendation,
	ProviderConfig,
	ProviderInfo,
	RateLimitInfo,
)


def _instantiate_dataclass(cls: type, overrides: dict[str, Any] | None = None) -> Any:
	"""Instantiate an unknown dataclass by filling required fields with generic values."""
	assert dataclasses.is_dataclass(cls), f"{cls} is expected to be a dataclass"
	overrides = overrides or {}

	kwargs: dict[str, Any] = {}
	for f in dataclasses.fields(cls):
		if f.name in overrides:
			kwargs[f.name] = overrides[f.name]
			continue
		# Skip fields that have defaults/default_factories
		if f.default is not dataclasses.MISSING:
			continue
		if f.default_factory is not dataclasses.MISSING:  # type: ignore[comparison-overlap]
			continue

		# Best-effort based on type
		ft = f.type
		if ft is str:
			kwargs[f.name] = f"test_{f.name}"
		elif ft is int:
			kwargs[f.name] = 1
		elif ft is float:
			kwargs[f.name] = 1.0
		elif ft is bool:
			kwargs[f.name] = True
		else:
			# Fallback
			kwargs[f.name] = None

	return cls(**kwargs)


class TestCompletionResponse:
	def test_can_create_with_all_fields(self):
		resp = CompletionResponse(
			content="hello",
			model="gpt-test",
			provider="test-provider",
			tokens_input=12,
			tokens_output=34,
			cost=0.001,
			latency_ms=123,
			finish_reason="stop",
			tool_calls=[{"name": "tool", "args": {"x": 1}}],
			raw_response={"id": "abc"},
		)
		assert resp.content == "hello"
		assert resp.model == "gpt-test"
		assert resp.provider == "test-provider"
		assert resp.tokens_input == 12
		assert resp.tokens_output == 34
		assert resp.cost == pytest.approx(0.001)
		assert resp.latency_ms == 123
		assert resp.finish_reason == "stop"
		assert resp.tool_calls == [{"name": "tool", "args": {"x": 1}}]
		assert resp.raw_response == {"id": "abc"}


class TestModelInfo:
	def test_capability_tags_roundtrip(self):
		mi = ModelInfo(
			name="model-a",
			display_name="Model A",
			provider="test-provider",
			context_window=128000,
			supports_tools=True,
			supports_streaming=True,
			supports_vision=False,
			is_free=False,
			cost_per_1k_input=0.5,
			cost_per_1k_output=1.0,
			capability_tags=["reasoning", "code"],
		)
		assert mi.capability_tags == ["reasoning", "code"]
		assert mi.supports_tools is True
		assert mi.context_window == 128000


class TestHealthStatus:
	def test_healthy_state(self):
		hs = HealthStatus(
			is_healthy=True,
			latency_ms=42,
			error=None,
			last_checked=datetime(2020, 1, 1, tzinfo=timezone.utc),
		)
		assert hs.is_healthy is True
		assert hs.error is None
		assert hs.latency_ms == 42

	def test_unhealthy_state(self):
		hs = HealthStatus(is_healthy=False, latency_ms=999, error="timeout", last_checked=None)
		assert hs.is_healthy is False
		assert hs.error == "timeout"
		assert hs.last_checked is None


class TestRateLimitInfo:
	def test_remaining_limits_roundtrip(self):
		rl = RateLimitInfo(
			rpm_limit=60,
			rpd_limit=1000,
			rpm_remaining=12,
			rpd_remaining=345,
			tpm_limit=120000,
			reset_at=datetime(2020, 1, 1, tzinfo=timezone.utc),
		)
		assert rl.rpm_limit == 60
		assert rl.rpm_remaining == 12
		assert rl.rpd_limit == 1000
		assert rl.rpd_remaining == 345
		assert rl.tpm_limit == 120000
		assert isinstance(rl.reset_at, datetime)


class TestProviderConfig:
	@pytest.mark.parametrize(
		"adapter_type, openai_compatible",
		[
			("openai", True),
			("anthropic", False),
			("local", False),
		],
	)
	def test_different_adapter_types(self, adapter_type: str, openai_compatible: bool):
		pc = ProviderConfig(
			name=f"{adapter_type}-provider",
			display_name=f"{adapter_type.title()} Provider",
			api_base_url="https://example.test/api",
			api_key_env_var="TEST_API_KEY",
			is_free=False,
			priority_score=10,
			openai_compatible=openai_compatible,
			adapter_type=adapter_type,
			config={"timeout": 30},
		)
		assert pc.adapter_type == adapter_type
		assert pc.openai_compatible is openai_compatible
		assert pc.config == {"timeout": 30}


class TestModelRecommendation:
	def test_has_score_and_reason(self):
		# We don't assume the full schema beyond "score" and "reason" existing.
		rec = _instantiate_dataclass(
			ModelRecommendation,
			overrides={
				"score": 0.99,
				"reason": "best overall",
			},
		)
		assert hasattr(rec, "score")
		assert hasattr(rec, "reason")
		assert rec.score == pytest.approx(0.99)
		assert rec.reason == "best overall"


class TestProviderInfo:
	def test_provider_info_is_dataclass_and_instantiable(self):
		assert dataclasses.is_dataclass(ProviderInfo), "ProviderInfo should be a dataclass"
		obj = _instantiate_dataclass(ProviderInfo, overrides={"name": "p1"} if "name" in {f.name for f in dataclasses.fields(ProviderInfo)} else {})
		# Minimal sanity: should expose something identifiable (common fields like name/display_name)
		for attr in ("name", "display_name", "provider"):
			if hasattr(obj, attr):
				assert getattr(obj, attr) is not None
				break
