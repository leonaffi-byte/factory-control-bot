"""Unit tests for the information barrier (black-box, per interfaces-v2.md)."""

from __future__ import annotations

import pytest

from app.orchestrator.information_barrier import (
	IMPLEMENTER_ALLOWED,
	IMPLEMENTER_BLOCKED,
	TESTER_ALLOWED,
	TESTER_BLOCKED,
	InformationBarrier,
)


class TestInformationBarrierAccess:
	@pytest.fixture
	def barrier(self) -> InformationBarrier:
		return InformationBarrier()

	@pytest.mark.parametrize(
		"file_path",
		[
			"artifacts/requirements/spec-v2.md",
			"artifacts/requirements/spec_foo.md",
			"artifacts/architecture/design-overview.md",
			"artifacts/architecture/interfaces-v2.md",
		],
	)
	def test_implementer_can_read_allowed_docs(self, barrier: InformationBarrier, file_path: str):
		assert barrier.validate_access("implementer", file_path, "read") is True

	def test_implementer_cannot_read_tests_artifacts(self, barrier: InformationBarrier):
		assert barrier.validate_access("implementer", "artifacts/tests/test_anything.py", "read") is False

	@pytest.mark.parametrize(
		"file_path",
		[
			"artifacts/requirements/spec-v2.md",
			"artifacts/architecture/interfaces-v2.md",
		],
	)
	def test_tester_can_read_spec_and_interfaces(self, barrier: InformationBarrier, file_path: str):
		assert barrier.validate_access("tester", file_path, "read") is True

	def test_tester_cannot_read_code_artifacts(self, barrier: InformationBarrier):
		assert barrier.validate_access("tester", "artifacts/code/main.py", "read") is False

	def test_tester_cannot_read_design_docs(self, barrier: InformationBarrier):
		assert barrier.validate_access("tester", "artifacts/architecture/design-overview.md", "read") is False


class TestInformationBarrierListsAndFiltering:
	@pytest.fixture
	def barrier(self) -> InformationBarrier:
		return InformationBarrier()

	def test_constants_are_non_empty(self):
		assert IMPLEMENTER_ALLOWED
		assert TESTER_ALLOWED
		assert IMPLEMENTER_BLOCKED
		assert TESTER_BLOCKED

	def test_get_allowed_files_returns_role_specific_patterns(self, barrier: InformationBarrier):
		implementer_patterns = barrier.get_allowed_files("implementer")
		tester_patterns = barrier.get_allowed_files("tester")

		assert isinstance(implementer_patterns, list)
		assert isinstance(tester_patterns, list)

		# Should at least include the patterns published as constants
		for p in IMPLEMENTER_ALLOWED:
			assert p in implementer_patterns
		for p in TESTER_ALLOWED:
			assert p in tester_patterns

	def test_filter_artifacts_removes_blocked_files(self, barrier: InformationBarrier):
		artifacts = {
			"artifacts/requirements/spec-v2.md": "spec",
			"artifacts/architecture/interfaces-v2.md": "interfaces",
			"artifacts/architecture/design-overview.md": "design",
			"artifacts/tests/test_anything.py": "tests",
			"artifacts/code/main.py": "code",
		}

		impl_view = barrier.filter_artifacts("implementer", artifacts)
		assert "artifacts/tests/test_anything.py" not in impl_view
		# Implementer is allowed spec/design/interfaces; may or may not include code depending on policy, but
		# at least the blocked tests must be removed.
		assert "artifacts/requirements/spec-v2.md" in impl_view
		assert "artifacts/architecture/interfaces-v2.md" in impl_view
		assert "artifacts/architecture/design-overview.md" in impl_view

		tester_view = barrier.filter_artifacts("tester", artifacts)
		assert "artifacts/code/main.py" not in tester_view
		assert "artifacts/architecture/design-overview.md" not in tester_view
		assert "artifacts/requirements/spec-v2.md" in tester_view
		assert "artifacts/architecture/interfaces-v2.md" in tester_view
</NEWFILE>

