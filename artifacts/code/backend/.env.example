# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ADMIN_TELEGRAM_ID=123456789

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://factory:factory_secret@localhost:5432/factory_bot
POSTGRES_PASSWORD=factory_secret

# ── External API Keys ─────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key
OPENAI_API_KEY=sk-your_openai_api_key
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key
GOOGLE_API_KEY=your_google_api_key
PERPLEXITY_API_KEY=pplx-your_perplexity_api_key
GITHUB_TOKEN=ghp_your_github_token

# ── Factory Configuration ────────────────────────────
FACTORY_ROOT_DIR=/home/factory/projects
TEMPLATES_DIR=/app/templates

# ── Monitoring ────────────────────────────────────────
LOG_POLL_INTERVAL=3
MAX_CONCURRENT_MONITORS=10
HEALTH_CHECK_INTERVAL=300
IDLE_TIMEOUT_MINUTES=10

# ── Defaults ──────────────────────────────────────────
DEFAULT_ENGINE=claude
QUALITY_GATE_THRESHOLD=97
MAX_QUALITY_RETRIES=3
MAX_FIX_CYCLES=5
COST_ALERT_THRESHOLD=50.0

# ── Voice / Translation ──────────────────────────────
VOICE_PROVIDER=auto
TRANSLATION_MODEL=gpt-4o-mini
REQUIREMENTS_MODEL=gpt-4o-mini

# ── Deployment ────────────────────────────────────────
# DOMAIN_NAME=example.com
# SSL_EMAIL=admin@example.com

# ── OpenRouter ────────────────────────────────────────
OPENROUTER_DAILY_LIMIT=200
OPENROUTER_WARN_THRESHOLD=0.8
OPENROUTER_BLOCK_THRESHOLD=0.95

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
